{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      },
      {
        "Name": "SQLite",
        "Args": {
          "sqliteDbPath": "Logs/TravelAppLogs.db",
          "tableName": "Logs"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "Key": "SuperSecretKeyForTravelApp1234567890",
    "Issuer": "TravelApp.WebApi",
    "Audience": "TravelApp.Users"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=TravelApp.db",
    "Redis": "localhost:6379"
  },
  "AllowedHosts": "*"
}
